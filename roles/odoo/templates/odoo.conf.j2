# {{ ansible_managed }}
# Configuration Odoo 19 CE — erp01.adlin.lab
# Monté dans le conteneur via docker-compose.yml

[options]
# Connexion PostgreSQL — le conteneur s'appelle "db" en réseau Docker
db_host          = db
db_port          = 5432
db_user          = {{ odoo_db_user }}
db_password      = {{ odoo_db_password }}
db_name          = {{ odoo_db_name }}

# Workers multi-process
workers          = {{ odoo_workers }}
max_cron_threads = {{ odoo_max_cron_threads }}

# Indispensable derrière nginx — lit X-Forwarded-Proto
proxy_mode       = True

# Données et logs (chemins internes au conteneur)
data_dir         = /var/lib/odoo
logfile          = /var/log/odoo/odoo.log
log_level        = info

# Pas de données de démo
without_demo     = True
