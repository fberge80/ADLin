# ==============================================================================
# ADLin — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Ansible Vault — ne JAMAIS commiter le mot de passe vault
# ------------------------------------------------------------------------------
.vault_pass
.vault_pass.txt
*.vault_pass

# ------------------------------------------------------------------------------
# Fichiers de retry Ansible (générés en cas d'échec de playbook)
# ------------------------------------------------------------------------------
*.retry

# ------------------------------------------------------------------------------
# Logs Ansible
# ------------------------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------------------------
# Clés SSH et certificats privés
# ------------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa

# ------------------------------------------------------------------------------
# Fichiers d'inventaire dynamiques générés localement
# ------------------------------------------------------------------------------
inventory/production/host_vars/*/secrets.yml
inventory/staging/host_vars/*/secrets.yml

# ------------------------------------------------------------------------------
# Fichiers de configuration locale (surcharge personnelle, non partageable)
# ------------------------------------------------------------------------------
ansible.cfg.local

# ------------------------------------------------------------------------------
# Environnements virtuels Python (si pip install ansible en venv local)
# ------------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# ------------------------------------------------------------------------------
# Vagrant (si utilisé pour tester les rôles localement)
# ------------------------------------------------------------------------------
.vagrant/
*.box

# ------------------------------------------------------------------------------
# Molecule (tests de rôles Ansible)
# ------------------------------------------------------------------------------
molecule/**/molecule.yml.bak
.molecule/

# ------------------------------------------------------------------------------
# Éditeurs et OS
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ------------------------------------------------------------------------------
# Fichiers temporaires et archives
# ------------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
